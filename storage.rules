rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // PDF files - authenticated users can read/write with size limit
    match /pdfs/{fileHash} {
      // Only authenticated users can read PDFs
      allow read: if request.auth != null;
      
      // Only authenticated users can upload, with 10MB size limit and PDF content type
      allow write: if request.auth != null 
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType == 'application/pdf';
    }
  }
}
